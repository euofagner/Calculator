<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="src.MainPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    BackgroundColor="{StaticResource Primary}">

    <Grid
        Padding="15"
        ColumnDefinitions="*, *, *, *"
        RowDefinitions="2*, *, *, *, *, *"
        RowSpacing="0">

        <Label
            x:Name="CurrentCalculation"
            Grid.Row="0"
            Grid.ColumnSpan="4"
            FontSize="22"
            HorizontalTextAlignment="End"
            LineBreakMode="NoWrap"
            Text=""
            TextColor="White"
            VerticalTextAlignment="Start" />

        <Label
            x:Name="lblResult"
            Grid.ColumnSpan="4"
            FontSize="50"
            HorizontalOptions="End"
            LineBreakMode="NoWrap"
            Text="0"
            TextColor="White"
            VerticalOptions="End" />

        <BoxView
            Grid.ColumnSpan="4"
            HeightRequest="1"
            VerticalOptions="End"
            Color="White" />

        <Button
            Grid.Row="1"
            Clicked="Button_Clicked_Clear"
            FontSize="25"
            Text="C" />

        <Button
            Grid.Row="1"
            Grid.Column="1"
            FontSize="25"
            Text="+/-" />

        <Button
            Grid.Row="1"
            Grid.Column="2"
            FontSize="25"
            Text="%" />

        <Button
            Grid.Row="2"
            Grid.Column="0"
            Clicked="Button_Number_Clicked"
            FontSize="25"
            Text="7" />

        <Button
            Grid.Row="2"
            Grid.Column="1"
            Clicked="Button_Number_Clicked"
            FontSize="25"
            Text="8" />

        <Button
            Grid.Row="2"
            Grid.Column="2"
            Clicked="Button_Number_Clicked"
            FontSize="25"
            Text="9" />

        <Button
            Grid.Row="3"
            Grid.Column="0"
            Clicked="Button_Number_Clicked"
            FontSize="25"
            Text="4" />

        <Button
            Grid.Row="3"
            Grid.Column="1"
            Clicked="Button_Number_Clicked"
            FontSize="25"
            Text="5" />

        <Button
            Grid.Row="3"
            Grid.Column="2"
            Clicked="Button_Number_Clicked"
            FontSize="25"
            Text="6" />

        <Button
            Grid.Row="4"
            Grid.Column="0"
            Clicked="Button_Number_Clicked"
            FontSize="25"
            Text="1" />

        <Button
            Grid.Row="4"
            Grid.Column="1"
            Clicked="Button_Number_Clicked"
            FontSize="25"
            Text="2" />

        <Button
            Grid.Row="4"
            Grid.Column="2"
            Clicked="Button_Number_Clicked"
            FontSize="25"
            Text="3" />

        <Button
            Grid.Row="5"
            Grid.Column="0"
            Clicked="Button_Number_Clicked"
            FontSize="25"
            Text="00" />

        <Button
            Grid.Row="5"
            Grid.Column="1"
            Clicked="Button_Number_Clicked"
            FontSize="25"
            Text="0" />

        <Button
            Grid.Row="5"
            Grid.Column="2"
            Clicked="Button_Number_Clicked"
            FontSize="25"
            Text="." />

        <Button
            Grid.Row="1"
            Grid.Column="3"
            Clicked="Button_Clicked_Operation"
            FontSize="25"
            Text="÷" />

        <Button
            Grid.Row="2"
            Grid.Column="3"
            Clicked="Button_Clicked_Operation"
            FontSize="25"
            Text="x" />

        <Button
            Grid.Row="3"
            Grid.Column="3"
            Clicked="Button_Clicked_Operation"
            FontSize="45"
            Opacity="0.9"
            Text="-" />

        <Button
            Grid.Row="4"
            Grid.Column="3"
            Clicked="Button_Clicked_Operation"
            FontSize="25"
            Text="+" />

        <Button
            Grid.Row="5"
            Grid.Column="3"
            Clicked="ResultButton_Clicked"
            FontSize="25"
            Text="=" />
    </Grid>

</ContentPage>
